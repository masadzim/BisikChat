<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content" android:layout_height="wrap_content"
    android:orientation="vertical" android:gravity="center"
    android:layout_marginHorizontal="6dp">
    <TextView android:id="@+id/partAvatar"
        android:layout_width="54dp" android:layout_height="54dp"
        android:gravity="center" android:text="?" android:textColor="#FFFFFF"
        android:textSize="20sp" android:textStyle="bold"
        android:background="@drawable/call_avatar_bg"/>
    <TextView android:id="@+id/partName"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Nama" android:textColor="#6B7799" android:textSize="11sp"
        android:layout_marginTop="4dp"/>
</LinearLayout>
