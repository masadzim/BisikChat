<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:gravity="end" android:padding="4dp">
    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:background="@drawable/bubble_mine" android:orientation="vertical"
        android:padding="10dp" android:layout_marginStart="60dp">
        <TextView android:id="@+id/msgText"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#FFFFFF" android:textSize="15sp"/>
        <TextView android:id="@+id/msgTime"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#AACCFF" android:textSize="10sp"
            android:layout_gravity="end" android:layout_marginTop="2dp"/>
    </LinearLayout>
</LinearLayout>
